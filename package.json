{
  "name": "llaminate",
  "version": "0.1.0",
  "description": "A simple but powerful library that abstracts LLM chat completions, providing chat history, tokens tracking and tools interfaces.",
  "main": "dist/llaminate.min.js",
  "types": "dist/llaminate.d.ts",
  "scripts": {
    "prebuild": "node scripts/prebuild.js",
    "build": "tsc && terser dist/llaminate.js -o dist/llaminate.min.js --source-map --comments 'some' && rm dist/llaminate.js dist/llaminate.js.map",
    "prepare": "npm run build",
    "test": "jest --i",
    "scratch": "node --env-file=.env ./tests/scratch.js"
  },
  "jest": {
    "runTestsByPath": true,
    "silent": true,
    "setupFiles": ["@dotenvx/dotenvx/config"],
    "testTimeout": 3600000,
    "openHandlesTimeout": 3600000,
    "passWithNoTests": true
  },
  "keywords": [
    "LLM",
    "AI",
    "chat",
    "completions",
    "streaming",
    "tools"
  ],
  "author": "Oliver Moran <oliver.moran@gmail.com>",
  "license": "MIT",
  "devDependencies": {
    "@dotenvx/dotenvx": "^1.55.1",
    "@types/node": "^25.5.0",
    "jest": "^30.3.0",
    "terser": "^5.46.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "ajv": "^8.18.0"
  }
}
