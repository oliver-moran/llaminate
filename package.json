{
  "name": "llaminate",
  "version": "0.2.4",
  "description": "A simple but powerful library that abstracts LLM chat completions, providing chat history, tokens tracking and tools interfaces.",
  "repository": "github:oliver-moran/llaminate",
  "homepage": "https://oliver-moran.github.io/llaminate/",
  "bugs": {
    "url": "https://github.com/oliver-moran/llaminate/issues"
  },
  "files": [
    "dist/**/*",
    "README.md",
    "LICENSE"
  ],
  "main": "dist/llaminate.min.js",
  "types": "dist/llaminate.d.ts",
  "scripts": {
    "prebuild": "node scripts/prebuild.js",
    "build": "bash scripts/build.sh",
    "docs": "bash scripts/docs.sh",
    "prepare": "bash scripts/prepare.sh",
    "pretest": "node scripts/pretest.js",
    "scratch": "node --env-file=.env ./tests/scratch.js",
    "test": "jest --i --config=./tests/jest.config.json"
  },
  "keywords": [
    "LLM",
    "AI",
    "chat",
    "completions",
    "streaming",
    "tools"
  ],
  "author": "Oliver Moran <oliver.moran@gmail.com>",
  "license": "MIT",
  "devDependencies": {
    "@dotenvx/dotenvx": "^1.55.1",
    "@types/node": "^25.6.0",
    "jest": "^30.3.0",
    "jsdoc": "^4.0.5",
    "terser": "^5.46.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "ajv": "^8.18.0",
    "handlebars": "^4.7.8"
  }
}
