{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "properties": {
        "endpoint": { "type": "string" },
        "key": { "type": "string" },
        "model": { "type": "string" },
        "schema": {
            "type": "object",
            "properties": {
                "type": { "type": "string" },
                "properties": { "type": "object" },
                "required": { "type": "array", "items": { "type": "string" } }
            },
            "additionalProperties": true
        },
        "system": {
            "type": "array",
            "items": { "type": "string" }
        },
        "attachments": {
            "type": "array",
            "items": {
                "type": "object",
                "properties": {
                    "type": { "type": "string", "enum": ["image", "document", "file"] },
                    "url": { "type": "string" },
                    "data": { "type": "string" },
                    "mime": { "type": "string" }
                },
                "oneOf": [
                    {
                        "properties": {
                            "type": { "enum": ["image", "document"] },
                            "url": { "type": "string" }
                        },
                        "required": ["type", "url"]
                    },
                    {
                        "properties": {
                            "type": { "enum": ["file"] },
                            "data": { "type": "string" },
                            "mime": { "type": "string" }
                        },
                        "required": ["type", "data", "mime"]
                    }
                ]
            }
        },
        "window": {
            "type": "integer",
            "minimum": 1
        },
        "tools": {
            "type": "array",
            "items": {
                "type": "object",
                "properties": {
                    "function": {
                        "type": "object",
                        "properties": {
                            "name": { "type": "string" },
                            "description": { "type": "string" },
                            "parameters": { "type": "object" },
                            "strict": { "type": "boolean" }
                        },
                        "required": ["name"]
                    },
                    "handler": { "not": { "type": "null" } }
                },
                "required": ["function"]
            }
        },
        "handler": { "not": { "type": "null" } },
        "options": {
            "type": "object",
            "additionalProperties": true
        },
        "headers": {
            "type": "object",
            "additionalProperties": {
                "type": "string"
            }
        },
        "rpm": {
            "type": "integer",
            "minimum": 1
        },
        "quirks": {
            "type": "object",
            "additionalProperties": {
                "type": "boolean"
            }
        },
        "fetch": { "not": { "type": "null" } }
    },
    "required": ["endpoint", "key", "model"],
    "additionalProperties": false
}