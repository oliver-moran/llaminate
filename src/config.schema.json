{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "properties": {
        "endpoint": { "type": "string" },
        "key": { "type": "string" },
        "model": { "type": "string" },
        "attachments": {
            "type": "array",
            "items": {
                "type": "object",
                "properties": {
                    "mime": { "type": "string" },
                    "url": { "type": "string" }
                },
                "required": ["mime", "url"]
            }
        },
        "headers": {
            "type": "object",
            "additionalProperties": {
                "type": "string"
            }
        },
        "history": {
            "type": "array",
            "items": {
                "type": "object",
                "properties": {
                    "role": { "type": "string", "enum": ["user", "assistant", "system", "tool", "developer"] },
                    "content": {},
                    "name": { "type": "string" },
                    "tool_calls": { "type": "array" },
                    "tool_call_id": { "type": "string" }
                },
                "oneOf": [
                    { "required": ["role", "content"] },
                    { "required": ["role", "tool_calls", "tool_call_id"] }
                ],
                "additionalProperties": true
            }
        },
        "input": { "not": { "type": "null" } },
        "limits": {
            "type": "object",
            "properties": {
                "tokens": { "type": "integer", "minimum": 1 },
                "recursions": { "type": "integer", "minimum": 0 },
                "attachments": { "type": "integer", "minimum": 0 }
            },
            "additionalProperties": true
        },
        "options": {
            "type": "object",
            "additionalProperties": true
        },
        "output": { "not": { "type": "null" } },
        "quirks": {
            "type": "object",
            "properties": {
                "attachments": {
                    "type": "object",
                    "properties": {
                        "document_url": { "type": "string", "enum": ["image_url"] },
                        "file": { "type": "boolean" },
                        "source": { "type": "boolean" }
                    },
                    "additionalProperties": true
                },
                "input_schema": { "type": "boolean" },
                "json_schema": { "type": "boolean" },
                "max_tokens": { "type": "integer", "minimum": 1 },
                "output_config": { "type": "boolean" },
                "role": {
                    "type": "object",
                    "properties": {
                        "system": { "type": "boolean" },
                        "tool": { "type": "boolean" }
                    },
                    "additionalProperties": true
                },
                "stream_options": { "type": "boolean" },
                "tools": {
                    "type": "object",
                    "properties": {
                        "json_schema": { "type": "boolean" },
                        "json_object": { "type": "boolean" },
                        "content": { "type": "array", "items": { "type": "string", "enum": ["string", "array"] } }
                    },
                    "additionalProperties": true
                }
            },
            "additionalProperties": true
        },
        "retries": {
            "type": "integer",
            "minimum": 0
        },
        "rpm": {
            "type": "integer",
            "minimum": 1
        },
        "schema": {
            "type": "object",
            "properties": {
                "type": { "type": "string" },
                "properties": { "type": "object" },
                "required": { "type": "array", "items": { "type": "string" } }
            },
            "additionalProperties": true
        },
        "system": {
            "type": "array",
            "items": { "type": "string" }
        },
        "tools": {
            "type": "array",
            "items": {
                "type": "object",
                "properties": {
                    "function": {
                        "type": "object",
                        "properties": {
                            "name": { "type": "string" },
                            "description": { "type": "string" },
                            "parameters": { "type": "object" },
                            "strict": { "type": "boolean" }
                        },
                        "required": ["name"]
                    },
                    "handler": { "not": { "type": "null" } }
                },
                "required": ["function"]
            }
        },
        "window": {
            "type": "integer",
            "minimum": 1
        },
        "fetch": { "not": { "type": "null" } },
        "handler": { "not": { "type": "null" } }
    },
    "required": ["endpoint", "key", "model"],
    "additionalProperties": false
}